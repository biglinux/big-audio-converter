# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 18
msgid ""
"Select the output audio format\n"
"\n"
"• copy: Keeps the original audio data — only cutting is available\n"
"• mp3: Widely supported, great balance between size and quality\n"
"• ogg: Open format, good quality at smaller file sizes\n"
"• flac: Lossless compression, perfect audio fidelity\n"
"• wav: Uncompressed format, very large files\n"
"• aac: Modern format with good overall quality\n"
"• opus: Excellent quality at low bitrates"
msgstr ""
"Изберете изходния аудио формат\n"
"\n"
"• копие: Запазва оригиналните аудио данни — налично е само рязане\n"
"• mp3: Широко поддържан, отличен баланс между размер и качество\n"
"• ogg: Отворен формат, добро качество при по-малки размери на файловете\n"
"• flac: Без загуби компресия, перфектна аудио фиделит\n"
"• wav: Некомпресиран формат, много големи файлове\n"
"• aac: Модерен формат с добро общо качество\n"
"• opus: Отлично качество при ниски битрейти"
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 28
msgid ""
"Choose the audio bitrate (quality level)\n"
"\n"
"• 32k: Very low quality\n"
"• 64k: Low quality\n"
"• 128k: Standard quality\n"
"• 192k: Good quality\n"
"• 256k: High quality\n"
"• 320k: Highest quality"
msgstr ""
"Изберете аудио битрейт (ниво на качество)\n"
"\n"
"• 32k: Много ниско качество\n"
"• 64k: Ниско качество\n"
"• 128k: Стандартно качество\n"
"• 192k: Добро качество\n"
"• 256k: Високо качество\n"
"• 320k: Най-високо качество"
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 37
msgid ""
"Adjust the audio volume\n"
"\n"
"• 100 = original volume\n"
"• < 100 = lower volume\n"
"• > 100 = higher volume\n"
"\n"
"Tip: Values above 100 may cause distortion"
msgstr ""
"Регулирайте звуковия обем\n"
"\n"
"• 100 = оригинален обем\n"
"• < 100 = по-нисък обем\n"
"• > 100 = по-висок обем\n"
"\n"
"Съвет: Стойности над 100 могат да причинят изкривяване"
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 44
msgid ""
"Change playback and conversion speed\n"
"\n"
"• 1.0 = normal speed\n"
"• < 1.0 = slower\n"
"• > 1.0 = faster\n"
"\n"
"Pitch correction is applied automatically"
msgstr ""
"Промяна на скоростта на възпроизвеждане и конвертиране\n"
"\n"
"• 1.0 = нормална скорост\n"
"• < 1.0 = по-бавно\n"
"• > 1.0 = по-бързо\n"
"\n"
"Корекция на височината се прилага автоматично"
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 65
msgid ""
"Reduce background noise during conversion\n"
"using the GTCRN neural network.\n"
"\n"
"Should not be used in music."
msgstr ""
"Намалете фоновия шум по време на конверсия, използвайки невронната мрежа GTCRN.\n"
"\n"
"Не трябва да се използва в музика."
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 70
msgid ""
"Adjust the intensity of noise reduction\n"
"\n"
"• 1.0 = maximum reduction\n"
"• 0.5 = moderate reduction\n"
"• Lower values preserve more original audio detail\n"
"\n"
"Tip: Start at 1.0 and reduce if the voice sounds muffled"
msgstr ""
"Настройте интензивността на намаляване на шума\n"
"\n"
"• 1.0 = максимално намаляване\n"
"• 0.5 = умерено намаляване\n"
"• По-ниските стойности запазват повече оригинални аудио детайли\n"
"\n"
"Съвет: Започнете с 1.0 и намалявайте, ако гласът звучи заглушен"
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 77
msgid ""
"Noise gate silences audio below a volume threshold\n"
"\n"
"Useful combined with noise reduction to eliminate\n"
"residual noise during pauses between speech.\n"
"\n"
"Should not be used in music."
msgstr ""
"Шумовата врата заглушава аудио под прага на звука\n"
"\n"
"Полезно в комбинация с намаляване на шума за елиминиране\n"
"на остатъчния шум по време на паузи между речта.\n"
"\n"
"Не трябва да се използва в музика."
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 83
msgid ""
"Volume level below which the gate closes\n"
"\n"
"• Higher values (e.g. -20 dB): Gate closes more often\n"
"• Lower values (e.g. -50 dB): Gate only closes in near-silence"
msgstr ""
"Ниво на звука, под което вратата се затваря\n"
"\n"
"• По-високи стойности (напр. -20 dB): Вратата се затваря по-често\n"
"• По-ниски стойности (напр. -50 dB): Вратата се затваря само при почти тишина"
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 88
msgid ""
"How much the audio is attenuated when the gate closes\n"
"\n"
"• -60 dB: Almost complete silence\n"
"• -20 dB: Gentle reduction, some background remains"
msgstr ""
"Колко е намалено аудиото, когато вратата се затвори\n"
"\n"
"• -60 dB: Почти пълна тишина\n"
"• -20 dB: Леко намаление, остава малко фонова звукова среда"
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 93
msgid ""
"How quickly the gate opens when signal exceeds threshold\n"
"\n"
"• Low values (5 ms): Fast opening, may cause clicks\n"
"• High values (50+ ms): Smooth opening, may cut speech starts"
msgstr ""
"Колко бързо се отваря вратата, когато сигналът надвиши прага\n"
"\n"
"• Ниски стойности (5 мс): Бързо отваряне, може да предизвика щраквания\n"
"• Високи стойности (50+ мс): Гладко отваряне, може да прекъсне началото на речта"
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 98
msgid ""
"How quickly the gate closes after signal drops below threshold\n"
"\n"
"• Low values (50 ms): Fast closing, may cut word endings\n"
"• High values (300+ ms): Smooth closing, keeps natural tails"
msgstr ""
"Колко бързо затваря вратата след като сигналът падне под прага\n"
"\n"
"• Ниски стойности (50 мс): Бързо затваряне, може да отреже окончания на думи\n"
"• Високи стойности (300+ мс): Гладко затваряне, запазва естествени окончания"
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 56
msgid ""
"Display audio as a visual waveform\n"
"\n"
"Easily edit by viewing your audio as a waveform.\n"
"Disable this option to load large files faster."
msgstr ""
"Показвайте аудио като визуална вълнова форма\n"
"\n"
"Лесно редактирайте, като виждате вашето аудио като вълнова форма.\n"
"Деактивирайте тази опция, за да заредите големи файлове по-бързо."
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 61
msgid ""
"Adjust the sound frequencies\n"
"\n"
"Fine-tune bass, midrange, and treble to enhance your audio."
msgstr ""
"Настройте звуковите честоти\n"
"\n"
"Фино настройте баса, средните и високите тонове, за да подобрите звука си."
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 65
msgid ""
"Cut and export selected parts of your audio\n"
"\n"
"• Off: Converts the entire file\n"
"• Chronological: Exports segments in timeline order\n"
"• Segment Number: Exports segments by marking order"
msgstr ""
"Изрежете и експортирайте избраните части от вашето аудио\n"
"\n"
"• Изключено: Преобразува целия файл\n"
"• Хронологично: Експортира сегменти в реда на времевата линия\n"
"• Номер на сегмент: Експортира сегменти по ред на маркиране"
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 118
msgid ""
"Choose how cut segments are saved\n"
"\n"
"• Separate Files: Each segment becomes its own file\n"
"• Merge into One: All segments are joined into a single file"
msgstr ""
"Изберете как да се запазят нарязаните сегменти\n"
"\n"
"• Отделни файлове: Всеки сегмент става собствен файл\n"
"• Сливане в един: Всички сегменти се обединяват в един файл"
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 123
msgid ""
"Limit the number of audio channels\n"
"\n"
"• Original: Keeps the source channel layout\n"
"• Mono: Downmix to 1 channel\n"
"• Stereo: Limit to 2 channels\n"
"\n"
"Useful for reducing file size or ensuring compatibility"
msgstr ""
"Ограничете броя на аудио каналите\n"
"\n"
"• Оригинален: Запазва изходния канален формат\n"
"• Моно: Смесва в 1 канал\n"
"• Стерео: Ограничете до 2 канала\n"
"\n"
"Полезно за намаляване на размера на файла или осигуряване на съвместимост"
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 130
msgid ""
"Click the top half to seek playback\n"
"Click the bottom half to set cut markers:\n"
"  1st click → Start (red) · 2nd click → End (green)\n"
"Scroll to zoom in/out for precision"
msgstr ""
"Щракнете горната половина, за да търсите възпроизвеждане  \n"
"Щракнете долната половина, за да зададете маркери за рязане:  \n"
"  1-во щракване → Начало (червено) · 2-ро щракване → Край (зелено)  \n"
"Превъртете, за да увеличите/намалите за прецизност"
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 82
msgid "You're seeing an example of help shown when hovering over an item."
msgstr "Виждате пример за помощ, показан при задържане на курсора над елемент."
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 86
msgid "Remove all files from the queue"
msgstr "Премахнете всички файлове от опашката."
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 89
msgid "Go to the previous audio file in the queue"
msgstr "Отидете на предишния аудиофайл в опашката."
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 92
msgid "Play or pause the current audio"
msgstr "Възпроизведете или паузирайте текущото аудио"
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 95
msgid "Go to the next audio file in the queue"
msgstr "Отидете до следващия аудиофайл в опашката"
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/ui/main_window.py, line: 475
msgid "When enabled, playback automatically plays only the marked segments, skipping unselected parts"
msgstr ""
"Когато е активирано, възпроизвеждането автоматично възпроизвежда само маркираните сегменти, "
"пропускайки неизбраните части."
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/ui/main_window.py, line: 500
msgid "When enabled, automatically plays the next track when current track finishes"
msgstr "Когато е активирано, автоматично възпроизвежда следващата песен, когато текущата песен завърши."
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 149
msgid "Show or hide the equalizer panel to adjust audio frequencies"
msgstr "Покажете или скрийте панела на еквалайзера, за да регулирате аудио честотите."
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 150
msgid "Open zoom control to adjust the waveform view magnification"
msgstr "Отворете контролата за увеличение, за да регулирате увеличението на изгледа на вълновата форма."
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 151
msgid "Adjust the output volume level (0-1000%)"
msgstr "Настройте нивото на изходния звук (0-1000%)"
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 152
msgid "Adjust the playback and conversion speed"
msgstr "Настройте скоростта на възпроизвеждане и конвертиране."
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 105
msgid "Preview this audio file"
msgstr "Прегледайте този аудиофайл."
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 108
msgid "Remove this file from the queue"
msgstr "Премахнете този файл от опашката."
# 
# File: big-audio-converter/big-audio-converter/usr/share/biglinux/audio-converter/app/utils/tooltip_helper.py, line: 111
msgid "Right-click for more options"
